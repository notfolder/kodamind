# rpi-voice-agent / .env.example
# cp .env.example .env してから値を編集してください。
# このファイル自体は Git で管理されます（機密情報を書き込まないこと）。

# ════════════════════════════════
#  必須項目
# ════════════════════════════════

# Hermes Agent API 認証キー
# 生成方法: openssl rand -hex 32
HERMES_API_KEY=your-strong-api-key-here

# Home Assistant 管理者アカウント（setup.sh が自動作成）
HA_USERNAME=admin
HA_PASSWORD=your-ha-password-here
HA_DISPLAY_NAME=Admin

# ════════════════════════════════
#  任意項目（デフォルト値あり）
# ════════════════════════════════

# タイムゾーン（全サービス共通）
# TZ=Asia/Tokyo

# Ollama: デフォルトモデル（初回起動時に自動 pull）
# OLLAMA_DEFAULT_MODEL=qwen2.5:3b

# Ollama: メモリ・並列設定（Pi 5 は PARALLEL=1 推奨）
# OLLAMA_KEEP_ALIVE=5m
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_LOADED_MODELS=1

# ウェイクワード名（openWakeWord のデフォルトモデル名）
# WAKE_WORD=ok_nabu

# Whisper STT 設定
# WHISPER_MODEL=tiny-int8      # 精度優先なら base-int8 / small-int8
# WHISPER_LANGUAGE=ja

# VOICEVOX TTS 話者 ID（https://voicevox.hiroshiba.jp/ でキャラクター一覧確認）
# 代表的な ID: 3=四国めたん(ノーマル) 2=ずんだもん 8=春日部つむぎ 13=青山龍星
# VOICEVOX_SPEAKER=3
