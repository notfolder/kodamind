# rpi-voice-agent / .env.example
# cp .env.example .env してから値を編集してください。
# このファイル自体は Git で管理されます（機密情報を書き込まないこと）。

# ════════════════════════════════
#  必須項目
# ════════════════════════════════

# Hermes Agent API 認証キー
# 生成方法: openssl rand -hex 32
HERMES_API_KEY=aa868b039d3de54272de9e3c5e8e4bbd33522e724e2322f245cdf9cf1ba5a209

# Home Assistant 管理者アカウント（setup.sh が自動作成）
HA_USERNAME=admin
HA_PASSWORD=p@ssword123
HA_DISPLAY_NAME=Admin

# ════════════════════════════════
#  任意項目（デフォルト値あり）
# ════════════════════════════════

# タイムゾーン（全サービス共通）
# TZ=Asia/Tokyo

# Ollama: デフォルトモデル（初回起動時に自動 pull）
OLLAMA_DEFAULT_MODEL=qwen2.5:3b

# Ollama: メモリ・並列設定（Pi 5 は PARALLEL=1 推奨）
# OLLAMA_KEEP_ALIVE=5m
# OLLAMA_NUM_PARALLEL=1
# OLLAMA_MAX_LOADED_MODELS=1

# ウェイクワード名（openWakeWord のデフォルトモデル名）
WAKE_WORD=hey_mycroft

# Whisper STT 設定
WHISPER_MODEL=small      # 精度優先なら base-int8 / small-int8
# WHISPER_LANGUAGE=ja

# Piper TTS 音声（https://rhasspy.github.io/piper-samples/ で一覧確認）
# PIPER_VOICE=ja_JP-takumi-medium
DBUS_RUN_DIR=/Users/notfolder/.rpi-voice-agent/dbus
PULSE_SERVER=tcp:host.docker.internal:4713

# Mac 専用: PulseAudio 入力ソース名（マイク）
# 空欄なら setup.sh が自動検出します。
# 確認方法: pactl list sources short
PULSE_MIC_SOURCE=1

# Mac 専用: PulseAudio 出力シンク名（スピーカー）
# 空欄なら setup.sh が自動検出します。
# 確認方法: pactl list sinks short
PULSE_SINK=1__2
